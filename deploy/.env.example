# JobHunt OS local deployment configuration.
#
# Copy this file to .env in this directory, edit the values, then run
# docker compose up -d from this deploy/ directory.

# Host-side address for Docker to publish. Keep 127.0.0.1 for local-only use or
# when a reverse proxy on the same host will provide HTTPS.
JOBHUNT_PUBLIC_BIND=127.0.0.1
JOBHUNT_PUBLIC_PORT=8080

# Built-in login auth is the recommended self-hosted default.
JOBHUNT_AUTH_MODE=login
JOBHUNT_AUTH_USERNAME=change-me

# The Compose file mounts this host file as a Docker secret and points
# JOBHUNT_AUTH_PASSWORD_FILE at it inside the container. Put a long password or
# passphrase in the file, not in this .env file.
JOBHUNT_AUTH_PASSWORD_SECRET_FILE=./.secrets/admin-password

# Set true when users access JobHunt OS through a trusted HTTPS reverse proxy.
# Keep false for plain HTTP localhost access.
JOBHUNT_SECURE_COOKIES=false

# Set true only when a trusted reverse proxy sanitizes X-Forwarded-For or
# X-Real-IP before requests reach JobHunt OS.
JOBHUNT_AUTH_TRUST_PROXY_HEADERS=false

# Login session lifetimes.
JOBHUNT_SESSION_IDLE_TIMEOUT=12h
JOBHUNT_SESSION_ABSOLUTE_TIMEOUT=30d

# Optional Linux bind-mount ownership. Set these to your host UID/GID if you
# want files in ./data to be owned by your user.
JOBHUNT_UID=65532
JOBHUNT_GID=65532
